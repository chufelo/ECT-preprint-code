digraph ECT_unification_clean {
    layout=neato;
    overlap=false;
    splines=true;
    outputorder=edgesfirst;
    bgcolor="white";
    pad=0.3;

    graph [fontname="Helvetica"];

    node [
        fontname="Helvetica",
        fontsize=30,
        color="#666666",
        penwidth=2.0,
        style="filled",
        fillcolor="#efefef",
        margin="0.26,0.20"
    ];

    edge [
        color="#505050",
        penwidth=2.0,
        arrowsize=1.0
    ];

    // ── Headers — explicitly no fill, no border ──
    pre_hdr [
        label="Pre-existing frameworks",
        shape=plain,
        style="",
        fillcolor="transparent",
        color="transparent",
        fontname="Helvetica-Bold",
        fontsize=32,
        fontcolor="#222222",
        pos="1.8,8.9!"
    ];
    bridge_hdr [
        label="ECT bridges between frameworks",
        shape=plain,
        style="",
        fillcolor="transparent",
        color="transparent",
        fontname="Helvetica-Bold",
        fontsize=32,
        fontcolor="#222222",
        pos="5.9,8.9!"
    ];

    // ── Left column  x=1.8,  step y=1.7 ──
    sm [shape=ellipse, fillcolor="#d9d9d9", width=4.4, height=1.85, pos="1.8,7.8!",
        label=<
            <TABLE BORDER="0" CELLPADDING="0" CELLSPACING="2" ALIGN="CENTER">
              <TR><TD ALIGN="CENTER"><B>Standard Model</B></TD></TR>
              <TR><TD ALIGN="CENTER">gauge bosons, fermions</TD></TR>
              <TR><TD ALIGN="CENTER">Higgs</TD></TR>
            </TABLE>
        >];

    qm [shape=ellipse, fillcolor="#d9d9d9", width=4.4, height=1.85, pos="1.8,6.1!",
        label=<
            <TABLE BORDER="0" CELLPADDING="0" CELLSPACING="2" ALIGN="CENTER">
              <TR><TD ALIGN="CENTER"><B>Quantum Mechanics</B></TD></TR>
              <TR><TD ALIGN="CENTER">&#295;, Schr&#246;dinger eq.</TD></TR>
              <TR><TD ALIGN="CENTER">uncertainty</TD></TR>
            </TABLE>
        >];

    cosmo [shape=ellipse, fillcolor="#d9d9d9", width=4.4, height=1.85, pos="1.8,4.4!",
        label=<
            <TABLE BORDER="0" CELLPADDING="0" CELLSPACING="2" ALIGN="CENTER">
              <TR><TD ALIGN="CENTER"><B>Cosmology</B></TD></TR>
              <TR><TD ALIGN="CENTER">dark energy, inflation</TD></TR>
              <TR><TD ALIGN="CENTER">JWST anomalies</TD></TR>
            </TABLE>
        >];

    gr [shape=ellipse, fillcolor="#d9d9d9", width=4.4, height=1.85, pos="1.8,2.7!",
        label=<
            <TABLE BORDER="0" CELLPADDING="0" CELLSPACING="2" ALIGN="CENTER">
              <TR><TD ALIGN="CENTER"><B>General Relativity</B></TD></TR>
              <TR><TD ALIGN="CENTER">curved spacetime</TD></TR>
              <TR><TD ALIGN="CENTER">G<SUB>N</SUB>, gravitation</TD></TR>
            </TABLE>
        >];

    thermo [shape=ellipse, fillcolor="#d9d9d9", width=4.4, height=1.85, pos="1.8,1.0!",
        label=<
            <TABLE BORDER="0" CELLPADDING="0" CELLSPACING="2" ALIGN="CENTER">
              <TR><TD ALIGN="CENTER"><B>Thermodynamics</B></TD></TR>
              <TR><TD ALIGN="CENTER">2nd law, entropy</TD></TR>
              <TR><TD ALIGN="CENTER">BH thermo.</TD></TR>
            </TABLE>
        >];

    // ── Middle column  x=5.9  (было 6.5, сдвинуто на −0.6) ──
    qmsm [shape=box, style="rounded,filled", width=5.1, height=1.75, pos="5.9,7.8!",
        label=<
            <TABLE BORDER="0" CELLPADDING="0" CELLSPACING="2" ALIGN="CENTER">
              <TR><TD ALIGN="CENTER"><B>QM &#215; SM</B></TD></TR>
              <TR><TD ALIGN="CENTER">Fermions (O(3) spinors)</TD></TR>
              <TR><TD ALIGN="CENTER">+ gauge bosons from phase sym.</TD></TR>
            </TABLE>
        >];

    smcosmo [shape=box, style="rounded,filled", width=5.1, height=1.75, pos="5.9,6.1!",
        label=<
            <TABLE BORDER="0" CELLPADDING="0" CELLSPACING="2" ALIGN="CENTER">
              <TR><TD ALIGN="CENTER"><B>SM &#215; Cosmo</B></TD></TR>
              <TR><TD ALIGN="CENTER">Leptogenesis from condensate instantons;</TD></TR>
              <TR><TD ALIGN="CENTER">&#951;<SUB>B</SUB> ~ 9&#215;10<SUP>&#8722;10</SUP> (nearly solved)</TD></TR>
            </TABLE>
        >];

    grqm [shape=box, style="rounded,filled", width=5.1, height=1.75, pos="5.9,4.4!",
        label=<
            <TABLE BORDER="0" CELLPADDING="0" CELLSPACING="2" ALIGN="CENTER">
              <TR><TD ALIGN="CENTER"><B>GR &#215; QM</B></TD></TR>
              <TR><TD ALIGN="CENTER">Lorentzian metric + &#295;</TD></TR>
              <TR><TD ALIGN="CENTER">from ONE condensate</TD></TR>
            </TABLE>
        >];

    grcosmo [shape=box, style="rounded,filled", width=5.1, height=2.0, pos="5.9,2.7!",
        label=<
            <TABLE BORDER="0" CELLPADDING="0" CELLSPACING="2" ALIGN="CENTER">
              <TR><TD ALIGN="CENTER"><B>GR &#215; Cosmo</B></TD></TR>
              <TR><TD ALIGN="CENTER">G<SUB>eff</SUB>(r,z); rot. curves (SPARC 148 gal.)</TD></TR>
              <TR><TD ALIGN="CENTER">dark energy + Hubble tension</TD></TR>
              <TR><TD ALIGN="CENTER">DESI DR2 2025 compatible</TD></TR>
            </TABLE>
        >];

    grthermo [shape=box, style="rounded,filled", width=5.1, height=1.75, pos="5.9,1.0!",
        label=<
            <TABLE BORDER="0" CELLPADDING="0" CELLSPACING="2" ALIGN="CENTER">
              <TR><TD ALIGN="CENTER"><B>GR &#215; Thermo</B></TD></TR>
              <TR><TD ALIGN="CENTER">BH entropy derived;</TD></TR>
              <TR><TD ALIGN="CENTER">arrow of time from &#915;<SUB>loop</SUB></TD></TR>
            </TABLE>
        >];

    // ── ECT core  x=11.0  (было 12.0, −1.0) ──
    ect [shape=box, style="rounded,filled",
        fillcolor="#1e1e1e", color="#111111", fontcolor="white",
        width=5.3, height=3.0, fontsize=30, pos="11.0,4.4!",
        label=<
            <TABLE BORDER="0" CELLPADDING="0" CELLSPACING="6" ALIGN="CENTER">
              <TR><TD ALIGN="CENTER"><FONT POINT-SIZE="38"><B>ECT</B></FONT></TD></TR>
              <TR><TD ALIGN="CENTER"><B>Euclidean Condensate Theory</B></TD></TR>
              <TR><TD ALIGN="CENTER"><B>One condensate field</B></TD></TR>
              <TR><TD ALIGN="CENTER"><B>O(4)&#8594;O(3) SSB</B></TD></TR>
            </TABLE>
        >];

    // ── Predictions  x=16.0  (было 17.2, −1.2) ──
    pred [shape=box, style="rounded,filled", width=5.3, height=4.9, pos="16.0,4.4!",
        label=<
            <TABLE BORDER="0" CELLPADDING="0" CELLSPACING="5" ALIGN="CENTER">
              <TR><TD ALIGN="CENTER"><B>ECT Predictions</B></TD></TR>
              <TR><TD ALIGN="CENTER"><B>(beyond bridges)</B></TD></TR>
              <TR><TD ALIGN="CENTER"> </TD></TR>
              <TR><TD ALIGN="CENTER">n<SUB>s</SUB> = 0.967</TD></TR>
              <TR><TD ALIGN="CENTER">g<SUP>&#8224;</SUP> from condensate</TD></TR>
              <TR><TD ALIGN="CENTER">5th force: &#969;<SUB>5</SUB> ~ 10<SUP>&#8722;10</SUP> rad/s</TD></TR>
              <TR><TD ALIGN="CENTER">LIV: |&#948;c/c| &lt; 10<SUP>&#8722;15</SUP></TD></TR>
              <TR><TD ALIGN="CENTER">JWST &#215;2&#8211;3 enhancement</TD></TR>
              <TR><TD ALIGN="CENTER">t<SUB>0</SUB> = 13.3&#8211;13.5 Gyr</TD></TR>
              <TR><TD ALIGN="CENTER">M<SUB>max</SUB> = 2.17 M<SUB>&#9737;</SUB></TD></TR>
              <TR><TD ALIGN="CENTER">&#951; ~ 10<SUP>&#8722;15</SUP> (MICROSCOPE-2)</TD></TR>
            </TABLE>
        >];

    // ── Edges ──
    sm -> qmsm [dir=none];
    sm -> grqm [dir=none];
    qm -> qmsm [dir=none];
    qm -> grqm [dir=none];
    cosmo -> smcosmo [dir=none];
    cosmo -> grcosmo [dir=none];
    gr -> grqm [dir=none];
    gr -> grcosmo [dir=none];
    gr -> grthermo [dir=none];
    thermo -> grthermo [dir=none];

    ect -> qmsm;
    ect -> smcosmo;
    ect -> grqm;
    ect -> grcosmo;
    ect -> grthermo;
    ect -> pred;
}
