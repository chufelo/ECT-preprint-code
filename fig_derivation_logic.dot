digraph ECT_derivation {
    rankdir=TB;
    bgcolor=white;
    fontname="Helvetica";
    fontsize=10;
    splines=ortho;
    nodesep=0.40;
    ranksep=0.58;
    margin=0.3;
    size="26,17";
    dpi=150;

    node [shape=box, style="filled,rounded", fontname=Helvetica, fontsize=10, margin=0.09];
    edge [fontname=Helvetica, fontsize=8];

    // ═══════════════════════════════════════════════════════════════
    // LAYER 0 — Postulates + Phenomenological inputs
    // ═══════════════════════════════════════════════════════════════
    { rank=same;
      P1  [label=<P1<BR/><B>4D Euclidean</B>>,
           fillcolor="#C8C8C8", color="#333333", fontname="Helvetica-Bold", width=1.72, height=0.50];
      P2  [label=<P2<BR/><B>O(4) action</B>>,
           fillcolor="#C8C8C8", color="#333333", fontname="Helvetica-Bold", width=1.72, height=0.50];
      P3  [label=<P3<BR/><B>Condensate &#934;</B>>,
           fillcolor="#C8C8C8", color="#333333", fontname="Helvetica-Bold", width=1.72, height=0.50];
      P4  [label=<P4<BR/><B>Gradient cond.</B>>,
           fillcolor="#C8C8C8", color="#333333", fontname="Helvetica-Bold", width=1.72, height=0.50];
      Ph1 [label=<Ph1<BR/><B>c* = c</B><BR/><I>(GW170817)</I>>,
           fillcolor="#777777", color="#222222", fontcolor=white, fontname="Helvetica-Bold", width=1.85, height=0.60];
      Ph2 [label=<Ph2<BR/><B>v&#8320;&#178;(&#945;&#8722;&#946;) = M&#772;<SUB>Pl</SUB>&#178;</B><BR/><I>(G<SUB>N</SUB> matching, obs.)</I>>,
           fillcolor="#777777", color="#222222", fontcolor=white, fontname="Helvetica-Bold", width=2.20, height=0.60];
    }

    // ═══════════════════════════════════════════════════════════════
    // LAYER 1
    // ═══════════════════════════════════════════════════════════════
    { rank=same;
      SSB   [label=<SSB<BR/>O(4) &#8594; O(3)<BR/><I>selects w-direction</I>>,
             fillcolor="#EBEBEB", color="#555555", width=2.10, height=0.60];
      Canon [label=<&#945; = 2&#946; (from c*=c)<BR/>&#946; = 1 (canonical norm.)>,
             fillcolor="#EBEBEB", color="#555555", width=2.10, height=0.50];
      Aniso [label=<Anisotropic coupling<BR/>L<SUB>E</SUB> + &#945;(n<SUP>A</SUP>&#8706;<SUB>A</SUB>&#934;)&#178;>,
             fillcolor="#EBEBEB", color="#555555", width=2.20, height=0.50];
    }
    P1->SSB; P2->SSB; P3->SSB; P4->SSB;
    Ph1->Canon;
    P2->Aniso; P4->Aniso;

    // ═══════════════════════════════════════════════════════════════
    // LAYER 2
    // ═══════════════════════════════════════════════════════════════
    { rank=same;
      Lor   [label=<Lorentzian metric<BR/>diag(&#8722;(&#945;&#8722;&#946;), &#946;, &#946;, &#946;)>,
             fillcolor="#EBEBEB", color="#555555", width=2.00, height=0.50];
      cstar [label=<c* = &#8730;(&#946;/(&#945;&#8722;&#946;))<BR/>light speed>,
             fillcolor="#EBEBEB", color="#555555", width=1.85, height=0.50];
      GN    [label=<G<SUB>N</SUB> = 1/(8&#960;v&#8320;&#178;(&#945;&#8722;&#946;))<BR/>grav. constant>,
             fillcolor="#EBEBEB", color="#555555", width=2.20, height=0.50];
      hbar  [label=<&#295; = v&#8320;&#8730;(&#946;/(&#955;(&#945;&#8722;&#946;)))<BR/>from phase stiffness>,
             fillcolor="#B0B0B0", color="#444444", width=2.10, height=0.50];
      Golds [label=<3 Goldstone bosons<BR/>&#126;10<SUP>&#8722;33</SUP> eV (fuzzy DM)>,
             fillcolor="#EBEBEB", color="#555555", width=1.95, height=0.50];
      GE    [label=<Euclidean correlator<BR/>G<SUB>E</SUB>(X,X')>,
             fillcolor="#EBEBEB", color="#555555", width=1.75, height=0.50];
    }
    SSB->Lor; SSB->cstar; SSB->GN; SSB->Golds; SSB->GE;
    Canon->Lor [style=dashed,color="#777777"]; Canon->cstar [style=dashed,color="#777777"];
    Canon->GN  [style=dashed,color="#777777"]; Ph2->GN [style=dashed,color="#777777"];
    P3->hbar   [style=dashed,color="#777777"]; Aniso->Lor [style=dashed,color="#777777"];

    // ═══════════════════════════════════════════════════════════════
    // LAYER 3
    // ═══════════════════════════════════════════════════════════════
    { rank=same;
      KG      [label=<Klein&#8211;Gordon<BR/>equation>,
               fillcolor="#EBEBEB", color="#555555", width=1.65, height=0.50];
      Wick    [label=<Wick rotation<BR/>w &#8594; &#8722;ic*t>,
               fillcolor="#EBEBEB", color="#555555", width=1.65, height=0.50];
      Sch     [label=<Schr&#246;dinger<BR/>equation>,
               fillcolor="#EBEBEB", color="#555555", width=1.65, height=0.50];
      Ein     [label=<Einstein eqs.<BR/>(linearised)>,
               fillcolor="#EBEBEB", color="#555555", width=1.65, height=0.50];
      Dir     [label=<Dirac equation<BR/>(O(3) spinors)>,
               fillcolor="#B0B0B0", color="#444444", width=1.65, height=0.50];
      Gauge   [label=<Gauge fields<BR/>U(1), SU(2)>,
               fillcolor="#B0B0B0", color="#444444", width=1.65, height=0.50];
      BH      [label=<BH thermo.<BR/>S = A/(4G<SUB>N</SUB>&#295;)>,
               fillcolor="#B0B0B0", color="#444444", width=1.65, height=0.50];
      Unruh   [label=<Unruh effect<BR/>T<SUB>U</SUB> = &#295;a/(2&#960;c*k<SUB>B</SUB>)>,
               fillcolor="#EBEBEB", color="#555555", width=1.85, height=0.50];
      Casimir [label=<Casimir effect<BR/>(F/A) = 3/2&#183;(F/A)<SUB>QED</SUB>>,
               fillcolor="#EBEBEB", color="#555555", width=1.95, height=0.50];
      Decoher [label=<Decoherence functional<BR/>&#915;[q], N<SUB>eff</SUB> &#8811; 1>,
               fillcolor="#EBEBEB", color="#555555", width=1.95, height=0.50];
    }
    Lor->KG; GE->Wick; Wick->Sch; hbar->Sch;
    GN->Ein; Lor->Ein;
    Lor->Dir [style=dashed,color="#777777"]; P3->Gauge [style=dashed,color="#777777"];
    GN->BH   [style=dashed,color="#777777"]; hbar->BH [style=dashed,color="#777777"];
    GE->Unruh; hbar->Unruh [style=dashed,color="#777777"];
    Golds->Casimir; KG->Decoher [style=dashed,color="#777777"];

    // ═══════════════════════════════════════════════════════════════
    // LAYER 4
    // ═══════════════════════════════════════════════════════════════
    { rank=same;
      RotC   [label=<Rotation curves<BR/>G<SUB>eff</SUB>(r), g&#8224; = c&#178;/r&#8320;<BR/>SPARC 148 gal., &#967;&#178;/N&#126;1.4>,
              fillcolor="#B0B0B0", color="#444444", width=2.00, height=0.60];
      Infl   [label=<Inflation / part. prod.<BR/>n<SUB>s</SUB> = 1&#8722;2/N<SUB>e</SUB> = 0.967>,
              fillcolor="#B0B0B0", color="#444444", width=1.90, height=0.50];
      DE     [label=<Dark energy<BR/>w&#8320; = &#8722;0.83, w<SUB>a</SUB> = &#8722;0.75<BR/>DESI DR2 2025 compat.>,
              fillcolor="#B0B0B0", color="#444444", width=2.00, height=0.60];
      Hubble [label=<Hubble tension<BR/>G<SUB>eff</SUB>(z) = G(1+z)<SUP>2&#949;</SUP><BR/>&#916;H&#8320; &#126; 3 km/s/Mpc>,
              fillcolor="#B0B0B0", color="#444444", width=2.00, height=0.60];
      FF     [label=<5th force<BR/>&#969;&#8325; &#126; 10<SUP>&#8722;10</SUP> rad/s<BR/>&#951; &#126; 10<SUP>&#8722;15</SUP> (MICROSCOPE-2)>,
              fillcolor="#B0B0B0", color="#444444", width=2.00, height=0.60];
      Lepto  [label=<Leptogenesis<BR/>&#951;<SUB>B</SUB> &#126; 9&#215;10<SUP>&#8722;10</SUP><BR/>(nearly solved, 1.5&#215; off)>,
              fillcolor="#B0B0B0", color="#444444", width=2.00, height=0.60];
      JWST   [label=<JWST galaxies<BR/>&#215;2&#8211;3 enhancement>,
              fillcolor="#B0B0B0", color="#444444", width=1.75, height=0.50];
      NSmax  [label=<Neutron star max.<BR/>M<SUB>max</SUB> = 2.17 M&#9737;<BR/>obs. PSR J0740: 2.14 M&#9737;>,
              fillcolor="#B0B0B0", color="#444444", width=2.00, height=0.60];
    }
    GN->RotC; Ein->Infl; Ein->DE;
    GN->Hubble  [style=dashed,color="#777777"]; Dir->FF   [style=dashed,color="#777777"];
    Gauge->Lepto[style=dashed,color="#777777"]; GN->JWST  [style=dashed,color="#777777"];
    Golds->Infl [style=dashed,color="#777777"]; Dir->NSmax[style=dashed,color="#777777"];
    GN->NSmax   [style=dashed,color="#777777"];

    // ═══════════════════════════════════════════════════════════════
    // LAYER 5
    // ═══════════════════════════════════════════════════════════════
    { rank=same;
      HUP   [label=<Uncertainty<BR/>principle>,
             fillcolor="#EBEBEB", color="#555555", width=1.65, height=0.50];
      law2  [label=<2nd law of thermo.<BR/>dS/dw &#8805; 0 (macro)<BR/>from d&#915;/dw &#8805; 0>,
             fillcolor="#EBEBEB", color="#555555", width=1.85, height=0.60];
      Arrow [label=<Arrow of time<BR/>emergent, N<SUB>eff</SUB> &#8811; 1>,
             fillcolor="#EBEBEB", color="#555555", width=1.65, height=0.50];
      LIV   [label=<Planck-scale LIV<BR/>|&#948;c/c| &lt; 10<SUP>&#8722;15</SUP>>,
             fillcolor="#B0B0B0", color="#444444", width=1.65, height=0.50];
      BTFR  [label=<BTFR: r&#8320; &#8733; M<SUB>&#9733;</SUB><SUP>1/3</SUP><BR/>pred. 0.333, obs. 0.383&#177;0.015<BR/>3.2&#963; tension>,
             style="dashed,rounded", fillcolor="#F0F0F0", color="#555555", width=2.10, height=0.60];
      CMB   [label=<CMB quadrupole<BR/>&#948;C&#8322;/C&#8322; &#126; e<SUP>&#8722;2&#960;</SUP> &#8776; 0.19<BR/>obs. &#126;0.13, 30% match>,
             style="dashed,rounded", fillcolor="#F0F0F0", color="#555555", width=2.10, height=0.60];
      SU3   [label=<SU(3), &#945;<SUB>fs</SUB><BR/>[OPEN]>,
             style="dashed,rounded", fillcolor=white, color="#888888", fontname="Helvetica-Oblique", width=1.65, height=0.50];
      Gen   [label=<3 generations<BR/>[OPEN]>,
             style="dashed,rounded", fillcolor=white, color="#888888", fontname="Helvetica-Oblique", width=1.65, height=0.50];
      OP0   [label=<Origin of &#934;<BR/>[OPEN]>,
             style="dashed,rounded", fillcolor=white, color="#888888", fontname="Helvetica-Oblique", width=1.65, height=0.50];
    }
    hbar->HUP; Decoher->law2; Decoher->Arrow;
    cstar->LIV [style=dashed,color="#777777"]; RotC->BTFR [style=dashed,color="#777777"];
    Ein->CMB   [style=dashed,color="#777777"]; Gauge->SU3 [style=dashed,color="#777777"];
    Dir->Gen   [style=dashed,color="#777777"]; P3->OP0    [style=dashed,color="#777777"];

    // ═══════════════════════════════════════════════════════════════
    // LEGEND — sink rank, horizontal, centered via wide invisible spans
    // ═══════════════════════════════════════════════════════════════

    // Invisible wide spacers force the legend to span the full width
    LanchorL [shape=point, width=0.01, style=invis];
    LanchorR [shape=point, width=0.01, style=invis];

    subgraph cluster_legend {
        label="Legend";
        style=rounded;
        color="#AAAAAA";
        bgcolor="#F5F5F5";
        fontname="Helvetica-Bold";
        fontsize=10;
        rank=sink;

        { rank=same;
          LanchorL;
          Lp  [label=<Postulate (P1&#8211;P4)>,
               fillcolor="#C8C8C8", color="#333333", fontname="Helvetica-Bold", fontsize=9, width=1.65, height=0.34];
          Lph [label=<Phenomenological input>,
               fillcolor="#777777", color="#222222", fontcolor=white, fontname="Helvetica-Bold", fontsize=9, width=1.65, height=0.34];
          LdA [label=<Derived &#8211; Level A (strict)>,
               fillcolor="#EBEBEB", color="#555555", fontsize=9, width=1.65, height=0.34];
          LdB [label=<Derived &#8211; Level B (+assump.)>,
               fillcolor="#B0B0B0", color="#444444", fontsize=9, width=1.65, height=0.34];
          LpB [label=<Prediction (tension/partial)>,
               style="dashed,rounded", fillcolor="#F0F0F0", color="#555555", fontsize=9, width=1.65, height=0.34];
          Lo  [label=<Open problem>,
               style="dashed,rounded", fillcolor=white, color="#888888", fontname="Helvetica-Oblique", fontsize=9, width=1.65, height=0.34];
          La1 [label="&#10230;  Strict derivation",
               shape=plain, style="", fillcolor=transparent, color=transparent, fontsize=9];
          La2 [label="&#8674;  Requires additional assumption",
               shape=plain, style="", fillcolor=transparent, color=transparent, fontsize=9];
          LanchorR;
          LanchorL->Lp->Lph->LdA->LdB->LpB->Lo->La1->La2->LanchorR [style=invis];
        }
    }

    // Pull legend anchors from the outermost Layer-5 nodes on each side
    HUP->LanchorL  [style=invis, weight=5];
    OP0->LanchorR  [style=invis, weight=5];
    // Extra pulls from middle to keep it from drifting
    law2->Lp       [style=invis, weight=1];
    Ein->LdA       [style=invis, weight=1];
    BTFR->LpB      [style=invis, weight=1];
}
