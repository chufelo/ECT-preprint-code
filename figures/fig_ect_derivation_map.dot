/*
 * ECT complete derivation map - v2 (4-fix: compact + zone arrows + high-contrast palette + right-shifted legend)
 *
 * Palette (grey-scale, high-contrast):
 *   Tier 0 Phi-medium   #333333 + white text, thick black border
 *   Postulates P1-P6    #707070 + white text
 *   Completion P_C      #a8a8a8 + white text, dashed border
 *   SSB                 #cfcfcf
 *   Lorentzian/Branches #e8e8e8
 *   Derived sectors     white + solid normal border
 *   Predictions/Falsif. white + solid thick border (NO fill)
 *   Open problems       white + dashed thick border
 */
digraph ECT {
  rankdir=TB;
  compound=true;
  fontname="Helvetica";
  node [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled",
        fillcolor="white", color="#333333", penwidth=1.2, margin="0.10,0.05"];
  edge [fontname="Helvetica", fontsize=8, color="black", penwidth=1.0];
  splines=true;
  nodesep=0.15;
  ranksep=0.18;
  ratio="1.25";

  /* ===== TIER 0: Phi-medium ===== */
  PHI [label=<<FONT COLOR="white"><B>&#934;-medium</B></FONT><BR/><FONT POINT-SIZE="9" COLOR="white">4D Euclidean manifold (&#8499;&#8308;, &#948;<SUB>AB</SUB>)  &#183;  Scalar condensate field &#934;</FONT>>,
       fillcolor="#333333", color="black", penwidth=2.2, fontsize=11];

  /* ===== TIER 1: Foundational Postulates P1-P6 (cluster) ===== */
  subgraph cluster_postulates {
    label=<<B>Foundational Postulates P1&#8211;P6</B>>; labeljust=c;
    style="rounded,dashed"; color="#666666"; fontsize=9; fontname="Helvetica";
    margin=4;
    ranksep=0.10;
    P1 [label=<<FONT COLOR="white"><B>P1</B>: 4D Euclidean arena</FONT>>, fillcolor="#707070"];
    P2 [label=<<FONT COLOR="white"><B>P2</B>: O(4)-invariant S<SUB>E</SUB>[&#936;]</FONT>>, fillcolor="#707070"];
    P3 [label=<<FONT COLOR="white"><B>P3</B>: Minimal scalar microdyn.</FONT>>, fillcolor="#707070"];
    P4 [label=<<FONT COLOR="white"><B>P4</B>: Ordered branch &#10216;&#8706;&#934;&#10217;&#8800;0</FONT>>, fillcolor="#707070"];
    P5 [label=<<FONT COLOR="white"><B>P5</B>: Medium character</FONT>>, fillcolor="#707070"];
    P6 [label=<<FONT COLOR="white"><B>P6</B>: Multiplicity of configs</FONT>>, fillcolor="#707070"];
    /* Single row of all 6 postulates — halves the cluster height. */
    {rank=same; P1; P2; P3; P4; P5; P6}
  }

  /* ===== TIER 1b: Completion hypothesis (cluster) ===== */
  subgraph cluster_completion {
    label=<<I>Completion hypothesis (Discussion)</I>>; labeljust=c;
    style="rounded,dashed"; color="#666666"; fontsize=9; fontname="Helvetica";
    margin=8;
    PC [label=<<FONT COLOR="white"><B>P<SUB>C</SUB></B>: Candidate internal<BR/>colour completion<BR/><FONT POINT-SIZE="9">Separate local complex rank-3 module<BR/>with SU(3)-structure &#183; Reverse-engineered</FONT></FONT>>,
        fillcolor="#a8a8a8", color="#333333", penwidth=1.4, style="rounded,filled,dashed"];
  }

  /* Zone-level arrows: Phi-medium -> both clusters (lhead points to cluster) */
  PHI -> P2 [lhead=cluster_postulates, minlen=1];
  PHI -> PC [lhead=cluster_completion, minlen=1];

  /* ===== TIER 2: SSB ===== */
  SSB [label=<<B>O(4) &#8594; O(3) Spontaneous Symmetry Breaking</B><BR/><FONT POINT-SIZE="9">Preferred direction n<SUB>A</SUB> = &#948;<SUB>Aw</SUB>  &#183;  Ordered condensate background</FONT>>,
       fillcolor="#cfcfcf", penwidth=1.5, fontsize=10];
  /* Zone-level arrow: whole postulate cluster -> SSB (ltail=cluster) */
  P5 -> SSB [ltail=cluster_postulates, minlen=1];

  /* ===== TIER 3: Emergent Lorentzian ===== */
  LOR [label=<<B>Emergent Lorentzian Structure</B><BR/><FONT POINT-SIZE="9">K<SUP>AB</SUP> = &#946;&#948;<SUP>AB</SUP> &#8722; &#945;n<SUP>A</SUP>n<SUP>B</SUP>  &#183;  &#945; &gt; &#946;<BR/>c<SUB>*</SUB>&#178; = &#946;/(&#945;&#8722;&#946;)  &#183;  Causal cone</FONT>>,
       fillcolor="#e8e8e8", penwidth=1.3, fontsize=10];
  SSB -> LOR [xlabel=<  &#945; &gt; &#946;  >];

  /* ===== TIER 4: Two branches ===== */
  MBRANCH [label=<<B>Macroscopic / Tensor Branch</B><BR/>(Part II)>, fillcolor="#e8e8e8", fontsize=10, penwidth=1.3];
  QBRANCH [label=<<B>Quantum / Coherent Branch</B><BR/>(Part III)>, fillcolor="#e8e8e8", fontsize=10, penwidth=1.3];
  LOR -> MBRANCH;
  LOR -> QBRANCH;
  {rank=same; MBRANCH; QBRANCH}

  /* Derived sectors: default white+solid (use default node style) */
  /* ===== MACROSCOPIC BRANCH ===== */
  GR [label=<<B>General Relativity</B><BR/><FONT POINT-SIZE="9">Fierz&#8211;Pauli &#8594; Einstein eqs.<BR/>&#920;<SUB>&#956;&#957;</SUB>[n,&#966;]  &#183;  G<SUB>eff</SUB>, &#923;<SUB>eff</SUB></FONT>>];
  MBRANCH -> GR;

  COSMO [label=<<B>Cosmology</B><BR/><FONT POINT-SIZE="9">&#923;<SUB>eff</SUB>  &#183;  Hubble-tension route<BR/>(n<SUB>s</SUB>, A<SUB>s</SUB>, r) native route: <I>open</I></FONT>>];
  GAL [label=<<B>Galactic Dynamics</B><BR/><FONT POINT-SIZE="9">&#966;-branch  &#183;  BTFR slope = 4<BR/>RAR  &#183;  g<SUB>&#8224;</SUB> &#8764; cH&#8320;/(2&#960;)</FONT>>];
  BH [label=<<B>Black Holes &amp; Strong Field</B><BR/><FONT POINT-SIZE="9">Info destruction excluded<BR/>Shell &#183; BH thermo &#183; Area law<BR/>Page curve: <I>open</I></FONT>>];
  FIFTH [label=<<B>5th Force</B><BR/><FONT POINT-SIZE="9">&#946;&#8325; &#8764; m<SUB>f</SUB>/M<SUB>Pl</SUB><BR/>M<SUB>max</SUB> &#8776; 2.17 M<SUB>&#8857;</SUB></FONT>>];
  CLUSTER [label=<<B>Cluster Lensing</B><BR/><FONT POINT-SIZE="9">Bullet, A520, El Gordo<BR/>&#957;-closure rule</FONT>>];

  GR -> COSMO;
  GR -> GAL;
  GR -> BH;
  GAL -> FIFTH;
  GAL -> CLUSTER;

  /* ===== CC Catastrophe Resolution (Theorem 1, Section 15) ===== */
  CC [label=<<B>CC Catastrophe Resolution</B><BR/><FONT POINT-SIZE="9">V(&#966;<SUB>0</SUB>) inert for emergent gravity [Level A]<BR/>&#8730;(&#8722;g<SUB>eff</SUB>) = &#946;&#178;/c<SUB>*</SUB> from n<SUP>A</SUP>n<SUB>A</SUB>=1<BR/>No 10&#185;&#178;&#8304; cross-scale cancellation invoked<BR/>&#961;<SUB>&#923;,obs</SUB> &#8764; c<SUB>&#923;</SUB>M<SUB>Pl</SUB>&#178;H<SUB>0</SUB>&#178; [Level C]</FONT>>];
  LOR -> CC [style=dashed];
  GR -> CC;
  CC -> OPEN [style=dashed, constraint=false];
  {rank=same; CC; GAL}

  /* ===== QUANTUM BRANCH ===== */
  S0 [label=<<B>Distinguished action scale S&#8320;</B><BR/><FONT POINT-SIZE="9">Winding sectors  &#183;  Phase quantisation<BR/>(existence, structural)</FONT>>];
  S0HBAR [label=<<B>S&#8320; = &#8463; matching</B><BR/><FONT POINT-SIZE="9">Physical identification<BR/>(Level B)</FONT>>];
  QBRANCH -> S0;
  S0 -> S0HBAR;

  SCHROD [label=<<B>Schr&#246;dinger Equation</B><BR/><FONT POINT-SIZE="9">Canonical phase dynamics<BR/>Uncertainty principle</FONT>>];
  VACUUM [label=<<B>Vacuum Response</B><BR/><FONT POINT-SIZE="9">Casimir (3/2)  &#183;  Unruh T<SUB>U</SUB><BR/>Particle production</FONT>>];
  DECOH [label=<<B>Decoherence &amp; Arrow of Time</B><BR/><FONT POINT-SIZE="9">Influence functional<BR/>Entropy  &#183;  Crooks relation</FONT>>];
  BORN [label=<<B>Born Rule</B><BR/><FONT POINT-SIZE="9">RP + Gleason conditional<BR/>(full Born: <I>open</I>)</FONT>>];
  TOPO [label=<<B>Exchange Topology &amp; Spinors</B><BR/><FONT POINT-SIZE="9">&#960;&#8321;(&#8499;&#8322;) = &#8484;&#8322;  &#183;  Dirac route<BR/>Entanglement</FONT>>];

  S0 -> SCHROD;
  S0 -> VACUUM;
  SCHROD -> DECOH;
  SCHROD -> BORN;
  LOR -> TOPO [style=dashed, xlabel=<d<SUB>sp</SUB>=3>];

  /* PES */
  PES [label=<<B>PES</B><BR/><FONT POINT-SIZE="9">Euclidean Stationarity<BR/>Selection criterion</FONT>>];
  DECOH -> PES;
  S0 -> PES [style=dashed];
  PES -> BORN;

  /* ===== GAUGE SECTOR (4 nodes) ===== */
  ABELIAN [label=<<B>Abelian gauge sector</B><BR/><FONT POINT-SIZE="9">U(1) phase route &#8594; photon-like sector<BR/>Charge lattice  &#183;  Full QED <I>open</I></FONT>>];
  EW [label=<<B>Electroweak architecture</B><BR/><FONT POINT-SIZE="9">Pre-locking SU(2)<SUB>orient</SUB>&#215;U(1)<SUB>&#952;</SUB> &#8594; U(1)<SUB>diag</SUB><BR/>Hopf-fibered S&#179; vacuum (App. Hopf-locking)<BR/>v&#8322;= &#966;<SUB>0</SUB> exp(&#8722;&#8459;<SUB>EW</SUB>), &#8459;<SUB>EW</SUB>&#8776;36.8<BR/>Layered OP-EW-* programme</FONT>>];
  FERMIONS [label=<<B>Fermionic reconstruction</B><BR/><FONT POINT-SIZE="9">O(3) spinor reps  &#183;  Dirac route<BR/>Neutrino seesaw  &#183;  M<SUB>R</SUB><SUP>geom</SUP> &#8764; 10&#185;&#8304; GeV<BR/>Yukawa / flavour: <I>open</I></FONT>>];
  COLOUR [label=<<B>Colour completion</B><BR/><FONT POINT-SIZE="9">SU(3)<SUB>c</SUB> via P<SUB>C</SUB> module<BR/>&#945;<SUB>s</SUB>, &#923;<SUB>QCD</SUB>, confinement: <I>open</I></FONT>>,
          style="rounded,filled,dashed", penwidth=1.4];

  S0 -> ABELIAN [xlabel=<phase>];
  S0 -> EW;
  TOPO -> FERMIONS [xlabel=<spinor>];
  ABELIAN -> EW [style=dashed];
  EW -> FERMIONS [style=dashed];
  PC -> COLOUR [ltail=cluster_completion, color="black", penwidth=1.2, style=dashed];

  /* ===== Unified origin of fundamental interactions ===== */
  UNIFICATION [label=<<B>Unified origin of fundamental interactions</B><BR/><FONT POINT-SIZE="9">Gravity + U(1) + SU(2)<SUB>L</SUB> + SU(3)<SUB>c</SUB> + fermions<BR/>Common pre-geometric origin in one condensate medium<BR/>[Level A (architectural unity);<BR/>Level B/C (full SM numerical closure)]</FONT>>,
               fillcolor="#cfcfcf", penwidth=1.8];
  GR       -> UNIFICATION [style=dashed];
  ABELIAN  -> UNIFICATION;
  EW       -> UNIFICATION;
  FERMIONS -> UNIFICATION;
  COLOUR   -> UNIFICATION [style=dashed];

  /* Discrete-symmetry / anomaly / flavour */
  CPT [label=<<B>Discrete-symmetry architecture</B><BR/><FONT POINT-SIZE="9">P, T, C  &#183;  Conditional CPT (OS)<BR/>Branch-pair on S&#179;  &#183;  Full nonlinear closure: <I>open</I></FONT>>];
  EW -> CPT;
  FERMIONS -> CPT [style=dashed];
  FIFTH -> CPT [style=dashed];

  ANOM [label=<<B>Anomaly architecture</B><BR/><FONT POINT-SIZE="9">Triangle + Witten inherited at EW<BR/>Full SM closure under (P<SUB>C</SUB>)<BR/>Mixed U(1)-grav: <I>open</I></FONT>>];
  EW -> ANOM;
  CPT -> ANOM [constraint=false];

  FLAVOUR [label=<<B>Flavour architecture</B><BR/><FONT POINT-SIZE="9">CKM/PMNS from overlap + seesaw<BR/>CP phases in Yukawa / Majorana<BR/>Numerical closure: <I>open</I></FONT>>];
  FERMIONS -> FLAVOUR;
  ANOM -> FLAVOUR [constraint=false];


  /* ===== PREDICTIONS / FALSIFIERS — no fill, solid thick border ===== */
  RESULTS [label=<<B>Results / Regime estimates</B><BR/><FONT POINT-SIZE="9">Procopio, Jacques<BR/>Bell threshold &#183; Qubit info bound</FONT>>];
  DECOH -> RESULTS;
  PES -> RESULTS;

  PRED_XS [label=<<B>Cross-sector predictions</B><BR/><FONT POINT-SIZE="9">LIV: |&#948;c/c| &lt; 10&#8315;&#185;&#8309;  &#183;  Casimir: 3/2 &#215; QED<BR/>Single c<SUB>*</SUB>  &#183;  Common S&#8320;  &#183;  No lab DM</FONT>>,
           fillcolor="white", style="rounded", penwidth=2.2];
  PRED_MACRO [label=<<B>Macroscopic / astrophysical predictions</B><BR/><FONT POINT-SIZE="9">g<SUB>&#8224;</SUB> &#8776; 1.1&#215;10&#8315;&#185;&#8304; m/s&#178;  &#183;  BTFR slope = 4<BR/>Env.-dep. g<SUB>&#8224;</SUB>  &#183;  M<SUB>max</SUB> &#8776; 2.17 M<SUB>&#8857;</SUB></FONT>>,
              fillcolor="white", style="rounded", penwidth=2.2];
  FALS [label=<<B>Cross-sector architectural falsifiers</B><BR/><FONT POINT-SIZE="9">Single c<SUB>*</SUB>, S&#8320;, UV threshold m<SUB>&#963;</SUB><BR/>No DM particles in lab<BR/>Env.-dep. transition morphology</FONT>>,
         fillcolor="white", style="rounded", penwidth=2.2];

  RESULTS -> PRED_XS;
  VACUUM  -> PRED_XS;
  CLUSTER -> PRED_MACRO [constraint=false, weight=5];
  COSMO   -> PRED_MACRO [constraint=false, weight=5];
  GAL     -> PRED_MACRO [weight=5];
  BH      -> PRED_MACRO [constraint=false, weight=5];
  PRED_XS    -> FALS;
  PRED_MACRO -> FALS [constraint=false];

  /* ===== OPEN PROBLEMS ===== */
  OPEN [label=<<B>Major open fronts</B><BR/><FONT POINT-SIZE="9">Strict identification S&#8320; = &#8463;  &#183;  Full first-principles Born rule<BR/>Full low-energy QFT architecture  &#183;  Full weak-gauge derivation<BR/>Full SM charge pattern  &#183;  Gauge anomaly cancellation<BR/>Full flavour closure (Yukawa, generations, &#957;-sector)<BR/>Why rank three / exact colour completion (P<SUB>C</SUB>)<BR/>Full nonlinear CPT (OP-CPT1)  &#183;  Page curve beyond shell<BR/>Full nonlinear GR  &#183;  Bell correlators  &#183;  &#945;<SUB>fs</SUB> = 1/137</FONT>>,
        fillcolor="white", style="rounded,dashed,filled", penwidth=2.2];

  FALS -> OPEN [style=dashed];
  BORN -> OPEN [style=dashed, constraint=false];
  S0HBAR -> OPEN [style=dashed, constraint=false];
  BH -> OPEN [style=dashed, constraint=false];
  COLOUR -> OPEN [style=dashed, constraint=false];
  CPT -> OPEN [style=dashed, constraint=false];
  ANOM -> OPEN [style=dashed, constraint=false];
  FLAVOUR -> OPEN [style=dashed, constraint=false];
  UNIFICATION -> OPEN [style=dashed, constraint=false];

  {rank=same; GR; S0}

  /* ===== LEGEND — anchored to RIGHT node only (shifts right from centre) ===== */
  LEGEND [shape=plaintext, fillcolor=white, label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="3" CELLPADDING="5" COLOR="black">
      <TR><TD COLSPAN="4"><B>Legend &#8211; ECT complete derivation map</B></TD></TR>
      <TR>
        <TD BGCOLOR="#333333"><FONT COLOR="white">&#934;-medium (Tier 0)</FONT></TD>
        <TD BGCOLOR="#707070"><FONT COLOR="white">Foundational postulate</FONT></TD>
        <TD BGCOLOR="#a8a8a8"><FONT COLOR="white">Completion candidate P<SUB>C</SUB></FONT></TD>
        <TD BGCOLOR="#cfcfcf">SSB</TD>
      </TR>
      <TR>
        <TD BGCOLOR="#e8e8e8">Lorentzian / branches</TD>
        <TD BGCOLOR="white" BORDER="1">Derived sector</TD>
        <TD BGCOLOR="white" BORDER="2">Predictions / Falsifiers (no fill)</TD>
        <TD BGCOLOR="white" BORDER="1" STYLE="DASHED">Open problem</TD>
      </TR>
      <TR>
        <TD COLSPAN="4"><B>Solid arrow:</B> strict derivation  &#8226;  <B>Dashed arrow:</B> assumption / open route</TD>
      </TR>
    </TABLE>
  >];
  /* FALS, OPEN, LEGEND on same rank (FALS left, OPEN middle, LEGEND right).
     Invisible heavy-weight pull from CC drags the whole row rightward. */
  {rank=same; FALS; OPEN; LEGEND}
  CC -> FALS [style=invis, weight=100, constraint=false];
  OPEN -> LEGEND [style=invis, weight=50];
}
